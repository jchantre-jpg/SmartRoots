# Copia a .env.local para desarrollo (opcional).
# En GitHub Pages usa Variables del repositorio (Settings → Actions → Variables).

# URL pública del backend Flask (sin barra final).
# Ejemplo túnel Cloudflare: https://abc-xyz.trycloudflare.com
# Vacío en dev local: el proxy de Vite usa /api → 127.0.0.1:5000
VITE_API_BASE=

# Solo para GitHub Pages si el repo NO es usuario.github.io
# Debe ser /nombre-del-repo/ con barras (ej. /SmartRoots/)
# Repo: https://github.com/jchantre-jpg/SmartRoots
VITE_BASE=/SmartRoots/
