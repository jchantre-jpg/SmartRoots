{
  "name": "smartrootsmovil",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "sync-web": "node scripts/sync-web-assets.js",
    "build:mobile": "npm run build:mobile --prefix ../frontend && npm run sync-web",
    "build:apk": "npx eas-cli build -p android --profile preview",
    "build:apk:prod": "npx eas-cli build -p android --profile production",
    "start:tunnel": "expo start --tunnel",
    "tunnel:backend": "node scripts/tunnel-backend.js"
  },
  "devDependencies": {
    "localtunnel": "^2.0.2"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.22",
    "expo-linear-gradient": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gifted-charts": "^1.4.77",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "private": true
}
